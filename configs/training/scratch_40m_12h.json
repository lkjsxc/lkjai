{
  "format": "lkjai-train-config-v1",
  "name": "scratch_40m_12h",
  "description": "Default RTX 3070 8GB 40M causal-LM run; 400k steps is a fixed estimate for roughly 12 hours on the known host.",
  "preset": "agent",
  "model_name": "lkjai-scratch-40m",
  "model_preset": "scratch-40m",
  "objective": "causal_lm_full",
  "vocab_size": 8192,
  "sequence_len": 1024,
  "layers": 10,
  "hidden_size": 576,
  "heads": 8,
  "kv_heads": 2,
  "ffn_size": 1536,
  "dropout": 0.0,
  "learning_rate": 0.0003,
  "weight_decay": 0.01,
  "beta1": 0.9,
  "beta2": 0.999,
  "eps": 0.00000001,
  "lr_schedule": "linear_warmup_cosine",
  "warmup_steps": 100,
  "lr_min_factor": 0.1,
  "activation_checkpoint": "every_n",
  "activation_checkpoint_every_n": 2,
  "checkpoint_preserve_rng": false,
  "batch_size": 2,
  "gradient_accumulation": 4,
  "batch_policy": "oom_fallback",
  "auto_batch": true,
  "auto_batch_max": 16,
  "target_effective_batch_tokens": 8192,
  "max_optimizer_steps": 400000,
  "max_microsteps": 0,
  "validate_every_optimizer_steps": 3000,
  "save_latest_every_optimizer_steps": 3000,
  "intermediate_save_every_optimizer_steps": 18000,
  "keep_last_checkpoints": 8,
  "checkpoint_resume_source": "latest",
  "log_every_optimizer_steps": 3000,
  "validation_batches": 8,
  "resume": "auto",
  "amp": "auto",
  "compile": "auto",
  "compile_warmup_microsteps": 2,
  "static_shapes": true,
  "attention_backend": "auto",
  "export_checkpoint": "best",
  "fixed_eval_threshold": 0.6,
  "behavioral_threshold": 0.35,
  "enforce_competency": false,
  "corpus_size": 120000,
  "corpus_tokens": 500000000,
  "corpus_dir": "/app/data/kimi-corpus",
  "curriculum": "configs/curriculum/agent_40m.toml",
  "seed": 42,
  "data_mode": "real",
  "dataloader_impl": "mapped",
  "num_workers": 0,
  "pin_memory": true,
  "prefetch_factor": 2,
  "persistent_workers": false,
  "allow_tf32": true,
  "matmul_precision": "high",
  "clip_grad_norm": 1.0,
  "profile_steps": 0,
  "benchmark_warmup_microsteps": 0,
  "dataloader_benchmark": false
}
