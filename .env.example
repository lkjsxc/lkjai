APP_HOST=127.0.0.1
APP_PORT=8080
DATA_DIR=/app/data
MODEL_API_URL=http://inference:8081/v1/chat/completions
MODEL_NAME=lkjai-scratch-40m
MODEL_CONTEXT_TOKENS=4096
MODEL_MAX_NEW_TOKENS=512
MODEL_TEMPERATURE=0.2
AGENT_MAX_STEPS=6
AGENT_REPAIR_ATTEMPTS=1
TOOL_TIMEOUT_SECS=20
TOOL_OUTPUT_LIMIT=12000
NVIDIA_VISIBLE_DEVICES=all
TRAIN_DATA_DIR=/app/data/train
TRAIN_PRESET=agent
TRAIN_MODEL_PRESET=scratch-40m
TRAIN_VOCAB_SIZE=8192
TRAIN_SEQUENCE_LEN=1024
TRAIN_LAYERS=8
TRAIN_HIDDEN_SIZE=512
TRAIN_HEADS=8
TRAIN_KV_HEADS=2
TRAIN_FFN_SIZE=1536
TRAIN_LEARNING_RATE=3e-4
TRAIN_GRADIENT_CHECKPOINTING=1
TRAIN_BATCH_SIZE=1
TRAIN_GRADIENT_ACCUMULATION=8
TRAIN_MAX_STEPS=500
TRAIN_CORPUS_SIZE=200
TRAIN_FIXED_EVAL_THRESHOLD=0.8
TRAIN_ENFORCE_COMPETENCY=0
