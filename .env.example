APP_HOST=127.0.0.1
APP_PORT=8080
DATA_DIR=/app/data
MODEL_API_URL=http://inference:8081/v1/chat/completions
MODEL_NAME=lkjai-scratch-60m
MODEL_CONTEXT_TOKENS=1024
MODEL_MAX_NEW_TOKENS=512
MODEL_TEMPERATURE=0.2
AGENT_MAX_STEPS=6
AGENT_REPAIR_ATTEMPTS=1
TOOL_WORKSPACE_DIR=/app/data/workspace
TOOL_TIMEOUT_SECS=20
TOOL_OUTPUT_LIMIT=12000
NVIDIA_VISIBLE_DEVICES=all
TRAIN_DATA_DIR=/app/data/train
TRAIN_PRESET=agent
TRAIN_MODEL_PRESET=scratch-60m
TRAIN_OBJECTIVE=causal_lm_full
TRAIN_VOCAB_SIZE=8192
TRAIN_SEQUENCE_LEN=1024
TRAIN_LAYERS=12
TRAIN_HIDDEN_SIZE=640
TRAIN_HEADS=8
TRAIN_KV_HEADS=2
TRAIN_FFN_SIZE=1792
TRAIN_LEARNING_RATE=3e-4
TRAIN_DROPOUT=0.0
TRAIN_GRADIENT_CHECKPOINTING=1
TRAIN_BATCH_SIZE=1
TRAIN_GRADIENT_ACCUMULATION=8
TRAIN_MAX_STEPS=120000
TRAIN_MAX_OPTIMIZER_STEPS=120000
TRAIN_MAX_MICROSTEPS=0
TRAIN_VALIDATE_EVERY_OPTIMIZER_STEPS=250
TRAIN_SAVE_EVERY_OPTIMIZER_STEPS=1000
TRAIN_VALIDATION_BATCHES=8
TRAIN_RESUME=auto
TRAIN_AMP=auto
TRAIN_TORCH_COMPILE=0
TRAIN_EXPORT_CHECKPOINT=best
TRAIN_BEHAVIORAL_CHECKPOINT=export
TRAIN_CORPUS_SIZE=120000
TRAIN_CORPUS_TOKENS=500000000
TRAIN_CORPUS_DIR=/app/data/kimi-corpus
TRAIN_COMMITTED_CORPUS_DIR=/workspace/training/corpus/kimi-full-v1
TRAIN_FIXED_EVAL_THRESHOLD=0.6
TRAIN_BEHAVIORAL_THRESHOLD=0.35
TRAIN_ENFORCE_COMPETENCY=0
