APP_HOST=127.0.0.1
APP_PORT=8080
DATA_DIR=/app/data
MODEL_API_URL=http://127.0.0.1:8081/v1/chat/completions
MODEL_NAME=qwen3-1.7b-q4
MODEL_GGUF=qwen3-1.7b-q4.gguf
MODEL_CONTEXT_TOKENS=4096
MODEL_MAX_NEW_TOKENS=512
MODEL_TEMPERATURE=0.2
AGENT_MAX_STEPS=6
AGENT_REPAIR_ATTEMPTS=1
TOOL_TIMEOUT_SECS=20
TOOL_OUTPUT_LIMIT=12000
NVIDIA_VISIBLE_DEVICES=all
TRAIN_DATA_DIR=/app/data/train
TRAIN_PRESET=quick
TRAIN_BASE_MODEL=Qwen/Qwen3-0.6B
TRAIN_SEQUENCE_LEN=2048
TRAIN_LORA_RANK=16
TRAIN_LORA_ALPHA=32
TRAIN_LEARNING_RATE=1e-4
TRAIN_LOAD_IN_4BIT=1
TRAIN_GRADIENT_CHECKPOINTING=1
TRAIN_FIXED_EVAL_THRESHOLD=0.8
TRAIN_ENFORCE_COMPETENCY=0
