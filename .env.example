APP_HOST=127.0.0.1
APP_PORT=8080
DATA_DIR=/app/data
MODEL_API_URL=http://inference:8081/v1/chat/completions
MODEL_NAME=lkjai-scratch-40m
MODEL_CONTEXT_TOKENS=1024
MODEL_MAX_NEW_TOKENS=512
MODEL_TEMPERATURE=0.2
AGENT_MAX_STEPS=6
AGENT_REPAIR_ATTEMPTS=1
TOOL_WORKSPACE_DIR=/app/data/workspace
TOOL_TIMEOUT_SECS=20
TOOL_OUTPUT_LIMIT=12000
NVIDIA_VISIBLE_DEVICES=all
TRAIN_DATA_DIR=/app/data/train
TRAIN_PRESET=agent
TRAIN_CONFIG=/workspace/configs/training/scratch_40m_12h.json
TRAIN_BEHAVIORAL_CHECKPOINT=export
TRAIN_COMMITTED_CORPUS_DIR=/workspace/training/corpus/kimi-full-v1
